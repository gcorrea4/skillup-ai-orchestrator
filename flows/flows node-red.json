    {
        "id": "ecd0f1dbc2d5f7d7",
        "type": "function",
        "z": "85d56ccb12d9b197",
        "name": "function 11",
        "func": "\ndelete msg.params;\ndelete msg.voice;\ndelete msg.responseUrl;\n\nvar intentGemini = 'pedir_trilha';\nvar irParaGemini = false;\nvar esperandoTema = flow.get(\"esperandoTema\") || false;\n\n\nvar textoAtual = \"\";\n\n\nif (msg.payload.input && msg.payload.input.text) {\n    textoAtual = msg.payload.input.text;\n}\nelse if (typeof msg.payload === 'string') {\n    textoAtual = msg.payload;\n}\nelse if (msg.originalMessage && msg.originalMessage.text) {\n    textoAtual = msg.originalMessage.text; \n}\n\n\nif (!textoAtual || textoAtual === \"Texto vazio\") {\n    textoAtual = \"Geral\";\n}\n\n\nif (msg.payload.output && msg.payload.output.intents && msg.payload.output.intents.length > 0) {\n    if (msg.payload.output.intents[0].intent === intentGemini) {\n        irParaGemini = true;\n    }\n}\n\n\n\n\nif (irParaGemini) {\n    flow.set(\"esperandoTema\", true);\n\n    var prompt = `Atue como um Mentor FIAP. O usuário disse: \"${textoAtual}\".\n    Se ele já disse o tema específico, crie a trilha. Se não, pergunte qual a área (ex: TI, Design).\n    Seja curto.`;\n\n    msg.payload = { contents: [{ parts: [{ text: prompt }] }] };\n    return [msg, null];\n}\n\n\nelse if (esperandoTema === true) {\n    flow.set(\"esperandoTema\", false);\n\n    \n    var prompt = `Atue como um Mentor Sênior da FIAP.\n    \n    CONTEXTO: O usuário quer estudar: \"${textoAtual}\".\n    \n    MISSÃO: Crie uma micro-trilha de estudos.\n    \n    REGRAS OBRIGATÓRIAS DE FORMATAÇÃO:\n    1. NÃO dê introduções longas, nem \"parabéns\", nem \"olá\". Vá direto ao ponto.\n    2. Gere APENAS uma lista numerada com 3 a 5 passos essenciais.\n    3. Use Emojis no início de cada passo.\n    4. Seja extremamente conciso (máximo de 1 frase por passo).\n    5. No final, coloque uma frase curta de motivação.\n    \n    Exemplo de como eu quero a resposta:\n    🎯 *Trilha de Python:*\n    1️⃣ Lógica de Programação e Variáveis\n    2️⃣ Estruturas de Dados e Loops\n    3️⃣ Orientação a Objetos\n    🚀 Bons estudos!`;\n\n    msg.payload = { contents: [{ parts: [{ text: prompt }] }] };\n    return [msg, null];\n}\n\n\nelse {\n    var textoParaFalar = \"Não entendi.\";\n    try {\n        if (msg.payload.output.generic && msg.payload.output.generic.length > 0) {\n            textoParaFalar = msg.payload.output.generic[0].text || \"Resposta sem texto.\";\n        }\n    } catch (e) { }\n\n    msg.payload = String(textoParaFalar);\n    return [null, msg];\n}",
