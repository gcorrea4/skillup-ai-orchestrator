        "z": "85d56ccb12d9b197",
        "name": "function 9",
        "func": "\nif (msg.payload.chatId) {\n    flow.set(\"chatId\", msg.payload.chatId);\n}\n\nif (msg.payload.type === 'voice') {\n    flow.set(\"tipoEntrada\", \"voz\"); \n    \n    \n    msg.url = msg.payload.weblink;\n    \n    \n    msg.params = {\n        'content_type': 'audio/ogg; codecs=opus'\n    };\n    \n    return [msg, null]; \n}\n\n\nif (msg.payload.content) {\n    flow.set(\"tipoEntrada\", \"texto\");\n    msg.payload = msg.payload.content;\n    return [null, msg]; \n}\n\nreturn null;",
